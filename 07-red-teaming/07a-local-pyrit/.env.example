# =============================================================================
# Sample 07a · Local PyRIT red-teaming — environment file
# Copy this file to ".env" (gitignored) and fill in the values below.
# =============================================================================

# --- Azure OpenAI deployment used as the "target under test" (AcmeBot) -------
# Find at: Foundry portal → your project → Models + Endpoints
#          OR Azure portal → your Azure OpenAI resource → Keys and Endpoint.
# Format:  https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://<YOUR_AOAI_RESOURCE>.openai.azure.com/

# A chat-completion model deployment name (NOT the family name).
# gpt-4o-mini is recommended for the workshop — it's the cheapest model that
# still has meaningful safety alignment to actually probe.
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Stable API version. Bump only if you know why.
AZURE_OPENAI_API_VERSION=2024-10-21
