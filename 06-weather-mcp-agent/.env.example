# --- Foundry project ---------------------------------------------------------
# Find this at: Microsoft Foundry portal → your project → Overview.
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>

# Any chat-completion model deployed in your project.
FOUNDRY_MODEL=gpt-4o

# --- Deployed Azure Functions MCP server ------------------------------------
# After `azd up` finishes, set:
#   WEATHER_MCP_ENDPOINT = the MCP_ENDPOINT output, ending in /runtime/webhooks/mcp
WEATHER_MCP_ENDPOINT=https://<your-func-app>.azurewebsites.net/runtime/webhooks/mcp

# --- Auth mode --------------------------------------------------------------
# WEATHER_MCP_AUTH=key   (iteration 1; Easy Auth OFF + host.json webhookAuth=System)
#   Set WEATHER_MCP_KEY to the `mcp_extension` system key:
#     az functionapp keys list \
#       --resource-group <rg> --name <func-name> \
#       --query systemKeys.mcp_extension -o tsv
#
# WEATHER_MCP_AUTH=entra (iteration 2; Easy Auth ON + host.json webhookAuth=Anonymous)
#   Set WEATHER_MCP_AUDIENCE to the App ID URI of the Entra app reg
#   protecting the Function App (created in Phase A of iteration 2).
#   Your `az login` user (or its SP) must be assigned the MCP.Invoke role.
#
# Leave WEATHER_MCP_AUTH unset to auto-detect: "entra" if WEATHER_MCP_AUDIENCE
# is non-empty, otherwise "key".
WEATHER_MCP_AUTH=
WEATHER_MCP_KEY=
WEATHER_MCP_AUDIENCE=api://<mcp-app-client-id>

# --- Observability ----------------------------------------------------------
# Same Application Insights connection string used by 02-mcp-tool-agent.py so
# the KQL cookbook can correlate spans across the agent and the Function App.
# Foundry portal → your project → Manage → Tracing.
APPLICATIONINSIGHTS_CONNECTION_STRING=
