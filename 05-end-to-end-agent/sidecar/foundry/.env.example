# Microsoft Foundry Edition — Environment Variables
# Copy to .env and fill in your values.
#
# =============================================================================
# ⚠️  .env IS FOR LOCAL DEVELOPMENT ONLY — NEVER DEPLOY IT TO PRODUCTION  ⚠️
# =============================================================================
# This file pattern stores secrets in plaintext. It is gitignored. .env must
# never be committed, shared, or copied to shared/remote environments.
#
# PRODUCTION on Azure (App Service / Container Apps) should use (zero stored secrets):
#   • Entra:   BLUEPRINT_CLIENT_SECRET → SourceType=SignedAssertionFromManagedIdentity
#   • Foundry: FOUNDRY_API_KEY → DefaultAzureCredential via Managed Identity
#              (grant the MI the "Azure AI Developer" / "Cognitive Services User"
#               role on the Foundry project)
# See: https://github.com/AzureAD/microsoft-identity-web/wiki/Client-Credentials
# See: https://learn.microsoft.com/en-us/azure/ai-studio/how-to/develop/sdk-overview
# =============================================================================

# Microsoft Entra Agent ID
TENANT_ID=
BLUEPRINT_APP_ID=
AGENT_CLIENT_ID=
CLIENT_SPA_APP_ID=

# Blueprint Client Credential (used by the auth sidecar)
# ⚠️ Dev-only. In prod, remove this and set SourceType=SignedAssertionFromManagedIdentity.
BLUEPRINT_CLIENT_SECRET=

# Microsoft Foundry — pick ONE of (A) or (B)
# Endpoint format (Foundry OpenAI-compatible API):
#   https://<aiservices-name>.services.ai.azure.com/openai/v1
# Model is the deployment name in your Foundry project.
FOUNDRY_ENDPOINT=
FOUNDRY_MODEL=gpt-4o-mini

# ─── (A) API key — simplest for local demo / workshops ───────────────────────
# Foundry portal → your project → Endpoints / Keys → copy "Key 1"
FOUNDRY_API_KEY=

# ─── (B) DefaultAzureCredential — recommended (no key in env) ────────────────
# Leave FOUNDRY_API_KEY blank. The agent container will reuse your `az login`
# session via the bind-mount of ~/.azure in docker-compose.yml.
# In Azure deployments this picks up Managed Identity automatically — no env vars.
# Optionally pin a specific service principal:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Microsoft Foundry Tracing — Application Insights connection string (optional).
# When set, the agent emits OpenTelemetry spans (LLM calls + tool calls + HTTP
# calls) to Application Insights. They appear in:
#   • Application Insights → Transaction search / Investigate → Application map
#   • Foundry portal → your project → Tracing  (App Insights must be linked to
#     the project: Foundry portal → Project → Tracing → Set up)
# Get the connection string from: Azure Portal → your App Insights resource →
# Overview → "Connection String". Looks like:
#   InstrumentationKey=xxxx-xxxx-xxxx;IngestionEndpoint=https://...
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Route LLM calls through the real azure-ai-inference SDK instead of the
# OpenAI-API path. This is required for spans to appear in the Foundry portal's
# Tracing tab (which filters for gen_ai.system="az.ai.inference"). Defaults to
# false to preserve the OpenAI-compatible behavior. When opted in, optionally
# point FOUNDRY_INFERENCE_ENDPOINT at the Foundry models URL:
#   https://<resource>.services.ai.azure.com/models
# If FOUNDRY_INFERENCE_ENDPOINT is empty, FOUNDRY_ENDPOINT is used as-is.
USE_FOUNDRY_INFERENCE_SDK=false
FOUNDRY_INFERENCE_ENDPOINT=
