# =============================================================================
# Workshop env file — copy this to ".env" (which is gitignored) and fill in.
# =============================================================================

# --- Microsoft Foundry project ---
# Find the endpoint at: Microsoft Foundry portal → your project → Overview
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://<YOUR_FOUNDRY_RESOURCE>.services.ai.azure.com/api/projects/<YOUR_PROJECT_NAME>
FOUNDRY_MODEL=gpt-4o

# Azure tenant for `az login --tenant <TENANT_ID>`
# Find via: az account show --query tenantId -o tsv
AZURE_TENANT_ID=<YOUR_TENANT_ID>

# --- Portal-first sample (02b) ---
# Name + version of an agent you've already created in the Foundry portal.
PORTAL_AGENT_NAME=<YOUR_PORTAL_AGENT_NAME>
PORTAL_AGENT_VERSION=1

# --- Application Insights for observability (02 / 02b / 02c) ---
# Find the connection string at: Foundry portal → your project → Manage → Tracing.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Required by verify_observability.py (the KQL smoke-test script).
APPLICATIONINSIGHTS_SUBSCRIPTION_ID=<YOUR_SUBSCRIPTION_ID>
APPLICATIONINSIGHTS_RESOURCE_GROUP=<YOUR_RESOURCE_GROUP>
APPLICATIONINSIGHTS_RESOURCE_NAME=<YOUR_APP_INSIGHTS_RESOURCE_NAME>
